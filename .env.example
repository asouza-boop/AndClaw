PORT=3000
NODE_ENV=development

# Telegram Setup
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
TELEGRAM_ALLOWED_USER_IDS="123456789,987654321"

# LLM Providers
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
DEEPSEEK_API_KEY="YOUR_DEEPSEEK_API_KEY"
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"  # Free models at openrouter.ai, no credit card needed
OLLAMA_MODEL="llama3.2"

# AI Config
DEFAULT_LLM_PROVIDER="gemini"
# Fallback chain: tries providers left-to-right on quota errors (429)
LLM_PROVIDER_CHAIN="gemini-flash,gemini-flash-lite,openrouter,deepseek"
MAX_ITERATIONS=5
