PORT=3000
NODE_ENV=development
DATABASE_URL="postgres://user:pass@host:5432/db"

# CORS — URL do frontend (ex: https://andclaw.vercel.app)
ALLOWED_ORIGIN="https://seu-frontend.vercel.app"

# Telegram Setup
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
TELEGRAM_ALLOWED_USER_IDS="123456789,987654321"

# Nome do usuário exibido pelo agente
AGENT_USER_NAME="Anderson"

# LLM Providers
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
DEEPSEEK_API_KEY="YOUR_DEEPSEEK_API_KEY"
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"  # Free models at openrouter.ai, no credit card needed
OLLAMA_MODEL="llama3.2"

# AI Config
DEFAULT_LLM_PROVIDER="gemini"
# Fallback chain: tries providers left-to-right on quota errors (429)
LLM_PROVIDER_CHAIN="gemini-flash,gemini-flash-lite,openrouter,deepseek"
MAX_ITERATIONS=5

# Google Calendar (JSON array of accounts)
# Example:
# GOOGLE_ACCOUNTS_JSON='[{"email":"you@example.com","clientId":"...","clientSecret":"...","redirectUri":"...","refreshToken":"...","calendarId":"primary","exportTasks":true}]'
GOOGLE_ACCOUNTS_JSON="[]"
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI=""
GOOGLE_EXPORT_CALENDAR_ID="primary"

# Intervalo de sync do Google Calendar em minutos (padrão: 30)
CALENDAR_SYNC_INTERVAL_MIN=30

# GitVault
GITVAULT_REPO="owner/repo"
GITHUB_TOKEN="ghp_..."
GITVAULT_BASE_PATH="daily"

# Web Push
VAPID_PUBLIC_KEY="your_public_key"
VAPID_PRIVATE_KEY="your_private_key"
VAPID_CONTACT_EMAIL="mailto:admin@example.com"

# Raindrop
RAINDROP_TOKEN=""
RAINDROP_COLLECTION_ID="0"

# Auth
AUTH_PASSWORD="change-me"
AUTH_TOKEN_SECRET="super-secret"
